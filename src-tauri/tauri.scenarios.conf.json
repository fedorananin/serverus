{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "me.fedorananin.serverus.scenarios",
  "build": {
    "beforeBuildCommand": "npm run build -- --mode scenarios"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        {
          "identifier": "scenario-tests",
          "description": "Test-only WebdriverIO access for the isolated scenario build",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:app:allow-set-app-theme",
            "drag:default",
            "dialog:default",
            "wdio:default",
            "wdio-webdriver:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": false
  }
}
